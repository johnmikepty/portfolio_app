# ── MongoDB ────────────────────────────────────────────────────────────────────
# Local (Docker): use the values below as-is for development
# Production:     use strong credentials and never commit this file

MONGO_USER=admin
MONGO_PASSWORD=admin1234

# Full connection string (used by the app)
# Local:      mongodb://admin:admin1234@localhost:27017/portfolio?authSource=admin
# Production: mongodb+srv://user:password@cluster.mongodb.net/portfolio
MONGODB_URI=mongodb://admin:admin1234@localhost:27017/portfolio?authSource=admin

# ── Mongo Express UI (http://localhost:8083) ───────────────────────────────────
# Basic auth credentials for the Mongo Express web UI (dev only, never expose in prod)
MONGOEXPRESS_USER=admin
MONGOEXPRESS_PASSWORD=admin1234

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generate a secure secret for production:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-random-secret
