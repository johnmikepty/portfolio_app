# MongoDB connection string
# Local (Docker): mongodb://admin:admin1234@localhost:27017/portfolio?authSource=admin
# Production (Atlas): mongodb+srv://user:password@cluster.mongodb.net/portfolio
MONGODB_URI=mongodb://admin:admin1234@localhost:27017/portfolio?authSource=admin

# JWT secret for CRM authentication (use a long random string in production)
JWT_SECRET=change-this-to-a-random-secret
