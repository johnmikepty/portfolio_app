---
import { getLocaleFromCookie, type Locale } from '@/i18n'
import { getPersonal, getExperienceDB, getProjectsDB, getSkillSectionsDB } from '@/lib/profile'
import LangToggle from '@/components/LangToggle.astro'

const cookieHeader = Astro.request.headers.get('cookie')
const locale: Locale = getLocaleFromCookie(cookieHeader)

const personal = await getPersonal(locale)
const experience = await getExperienceDB(locale)
const projects = await getProjectsDB(locale)
const skillSections = await getSkillSectionsDB()

const { name, title, email, phone, linkedin, github, location, bio } = personal

const services = locale === 'es'
    ? [
        { icon: '🌐', label: 'Aplicaciones Web', desc: 'SPAs, dashboards, portales y sistemas con React, Next.js, Astro y .NET Core.' },
        { icon: '🖥️', label: 'Apps de Escritorio', desc: 'Aplicaciones Windows robustas con .NET Framework, WPF y MAUI.' },
        { icon: '⌨️', label: 'CLIs & Scripts', desc: 'Herramientas de línea de comandos y automatización con Python, Node.js y Bash.' },
        { icon: '📱', label: 'Apps Móviles', desc: 'Aplicaciones iOS y Android con MAUI y soluciones híbridas.' },
        { icon: '⚙️', label: 'Flujos de Automatización', desc: 'Automatización de procesos con Power Automate, Python y RPA.' },
        { icon: '🔄', label: 'Tareas en Background', desc: 'Workers, jobs, colas de mensajes y procesamiento asíncrono.' },
        { icon: '🤖', label: 'Chatbots & IA', desc: 'Asistentes conversacionales, integraciones con LLMs y agentes inteligentes.' },
        { icon: '📊', label: 'QA & Testing', desc: 'Automatización de pruebas E2E, UI, API con Appium, Selenium y Cucumber.' },
    ]
    : [
        { icon: '🌐', label: 'Web Applications', desc: 'SPAs, dashboards, portals and systems with React, Next.js, Astro and .NET Core.' },
        { icon: '🖥️', label: 'Windows Applications', desc: 'Robust Windows desktop apps with .NET Framework, WPF and MAUI.' },
        { icon: '⌨️', label: 'CLI Apps & Scripts', desc: 'Command-line tools and automation scripts with Python, Node.js and Bash.' },
        { icon: '📱', label: 'Mobile Apps', desc: 'iOS and Android apps with MAUI and hybrid solutions.' },
        { icon: '⚙️', label: 'Automation Workflows', desc: 'Process automation with Power Automate, Python and RPA tools.' },
        { icon: '🔄', label: 'Background Tasks', desc: 'Workers, jobs, message queues and async processing pipelines.' },
        { icon: '🤖', label: 'Chatbots & AI Assists', desc: 'Conversational assistants, LLM integrations and intelligent agents.' },
        { icon: '📊', label: 'QA & Test Automation', desc: 'E2E, UI and API test automation with Appium, Selenium and Cucumber.' },
    ]

const highlights = locale === 'es'
    ? [
        { icon: '⚡', value: '14+', label: 'Años de Experiencia', sub: 'Fintech · E-commerce · Cloud' },
        { icon: '🏗️', value: 'LEAD', label: 'Líder Técnico & Mentor', sub: 'Premio a la Excelencia · OmegaTech' },
        { icon: '🔷', value: 'HEX', label: 'Arquitectura Hexagonal', sub: '.NET Core · OpenAPI · DDD' },
        { icon: '🤖', value: 'SDET', label: 'QA Automation Expert', sub: 'Appium · Selenium · Cucumber' },
    ]
    : [
        { icon: '⚡', value: '14+', label: 'Years of Experience', sub: 'Fintech · E-commerce · Cloud' },
        { icon: '🏗️', value: 'LEAD', label: 'Tech Lead & Mentor', sub: 'Award for Excellence · OmegaTech' },
        { icon: '🔷', value: 'HEX', label: 'Hexagonal Architecture', sub: '.NET Core · OpenAPI · DDD' },
        { icon: '🤖', value: 'SDET', label: 'QA Automation Expert', sub: 'Appium · Selenium · Cucumber' },
    ]
---

<!DOCTYPE html>
<html lang={locale}>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{name} — Portfolio</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
</head>
<body>

<LangToggle locale={locale} variant="dark" />

<!-- NAV -->
<nav class="nav" id="nav">
    <div class="nav-logo">{name.split(' ').slice(0,2).join(' ')}</div>
    <ul class="nav-links">
        <li><a href="#about">{locale === 'es' ? 'Sobre mí' : 'About'}</a></li>
        <li><a href="#experience">{locale === 'es' ? 'Experiencia' : 'Experience'}</a></li>
        <li><a href="#projects">{locale === 'es' ? 'Proyectos' : 'Projects'}</a></li>
        <li><a href="#skills">Skills</a></li>
        <li><a href="#contact">{locale === 'es' ? 'Contacto' : 'Contact'}</a></li>
        <li class="nav-resume-wrap">
            <span class="nav-cta">{locale === 'es' ? 'Resume' : 'Resume'} ▾</span>
            <div class="nav-dropdown">
                <a href="/resume">{locale === 'es' ? '👁 Ver Resume' : '👁 View'}</a>
                <a href="/api/download-resume" download="resume.pdf">{locale === 'es' ? '⬇ Descargar' : '⬇ Download'}</a>
            </div>
        </li>
    </ul>
</nav>

<!-- HERO -->
<section class="hero" id="about">
    <div class="hero-grid">
        <div class="hero-content">
            <p class="hero-eyebrow">// {location}</p>
            <h1 class="hero-name">{name}</h1>
            <h2 class="hero-role">
                {locale === 'es' ? 'SENIOR FULL STACK' : 'SENIOR FULL STACK'}<br>
                <span class="hero-role-accent">ENGINEER &amp; SDET</span>
            </h2>
            <p class="hero-bio">{bio}</p>
            <div class="hero-actions">
                <a href="#projects" class="btn-primary">{locale === 'es' ? 'Ver Proyectos' : 'View Projects'}</a>
                <a href="#contact" class="btn-secondary">{locale === 'es' ? 'Contactar' : 'Contact'}</a>
            </div>
            <div class="hero-tags">
                <span>.NET Core</span><span>React</span><span>Node.js</span><span>MongoDB</span><span>Docker</span><span>TypeScript</span>
            </div>
        </div>
        <div class="hero-visual">
            <div class="code-window">
                <div class="code-window-bar">
                    <span class="dot red"></span><span class="dot yellow"></span><span class="dot green"></span>
                    <span class="code-window-title">profile.ts</span>
                </div>
                <pre class="code-content"><code><span class="c-keyword">const</span> <span class="c-var">dev</span> = <span class="c-bracket">&#123;</span>
  name<span class="c-punct">:</span> <span class="c-str">"{name.split(' ')[0]}"</span><span class="c-punct">,</span>
  role<span class="c-punct">:</span> <span class="c-str">"Full Stack + SDET"</span><span class="c-punct">,</span>
  years<span class="c-punct">:</span> <span class="c-num">14</span><span class="c-punct">,</span>
  stack<span class="c-punct">:</span> <span class="c-bracket">[</span>
    <span class="c-str">".NET Core"</span><span class="c-punct">,</span>
    <span class="c-str">"React"</span><span class="c-punct">,</span>
    <span class="c-str">"Node.js"</span><span class="c-punct">,</span>
    <span class="c-str">"TypeScript"</span>
  <span class="c-bracket">]</span><span class="c-punct">,</span>
  passion<span class="c-punct">:</span> <span class="c-str">"Clean Architecture"</span>
<span class="c-bracket">&#125;</span>

<span class="c-keyword">export default</span> dev<span class="c-punct">;</span></code></pre>
            </div>
            <div class="hero-glow"></div>
        </div>
    </div>
    <div class="hero-scroll">
        <span>scroll</span>
        <div class="scroll-line"></div>
    </div>
</section>

<!-- HIGHLIGHTS -->
<section class="highlights" id="highlights">
    <div class="container">
        <div class="highlights-grid">
            {highlights.map(h => (
                <div class="highlight-card">
                    <div class="highlight-icon">{h.icon}</div>
                    <div class="highlight-value">{h.value}</div>
                    <div class="highlight-label">{h.label}</div>
                    <div class="highlight-sub">{h.sub}</div>
                </div>
            ))}
        </div>
    </div>
</section>

<!-- EXPERIENCE -->
<section class="section" id="experience">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">02</span>
            <h2 class="section-title">{locale === 'es' ? 'Experiencia' : 'Experience'}</h2>
        </div>
        <div class="timeline">
            {experience.map((exp, i) => (
                <div class="timeline-item">
                    <div class="timeline-dot"></div>
                    <div class="timeline-content">
                        <div class="timeline-meta">
                            <span class="timeline-period">
                                {exp.startYear} — {(exp.endYear && exp.endYear !== 0) ? exp.endYear : (locale === 'es' ? 'Presente' : 'Present')}
                            </span>
                            <span class="timeline-location">{exp.location}</span>
                        </div>
                        <h3 class="timeline-role">{exp.title}</h3>
                        <p class="timeline-company">{exp.name}</p>
                        <ul class="timeline-bullets">
                            {exp.bullets.slice(0, 3).map((b: string) => (
                                <li set:html={b.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')} />
                            ))}
                        </ul>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<!-- PROJECTS -->
<section class="section section-alt" id="projects">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">03</span>
            <h2 class="section-title">{locale === 'es' ? 'Proyectos Destacados' : 'Featured Projects'}</h2>
        </div>
        <div class="projects-grid">
            {projects.map((proj, i) => (
                <div class="project-card" data-index={i}>
                    <div class="project-card-header">
                        <div class="project-number">0{i + 1}</div>
                        <div class="project-card-glow"></div>
                    </div>
                    <h3 class="project-name">{proj.name}</h3>
                    <ul class="project-bullets">
                        {proj.bullets.slice(0, 2).map((b: string) => (
                            <li set:html={b.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')} />
                        ))}
                    </ul>
                    {proj.icons && proj.icons.length > 0 && (
                        <div class="project-tags">
                            {proj.icons.map((icon: string) => (
                                <span class="project-tag">{icon.split(':')[1]?.replace(/-icon$/, '') ?? icon}</span>
                            ))}
                        </div>
                    )}
                </div>
            ))}
            <!-- Extra project cards from resume -->
            <div class="project-card">
                <div class="project-card-header">
                    <div class="project-number">02</div>
                    <div class="project-card-glow"></div>
                </div>
                <h3 class="project-name">MINSA-SEIS Automation</h3>
                <ul class="project-bullets">
                    <li>{locale === 'es' ? 'Automatización de flujos de soporte técnico y creación masiva de usuarios en Active Directory.' : 'Automated support flows and bulk Active Directory user creation for MINSA health system.'}</li>
                </ul>
                <div class="project-tags">
                    <span class="project-tag">python</span>
                    <span class="project-tag">react</span>
                    <span class="project-tag">node</span>
                    <span class="project-tag">postgres</span>
                </div>
            </div>
            <div class="project-card">
                <div class="project-card-header">
                    <div class="project-number">03</div>
                    <div class="project-card-glow"></div>
                </div>
                <h3 class="project-name">MoneyStream — OmegaTech</h3>
                <ul class="project-bullets">
                    <li>{locale === 'es' ? 'Sistema financiero de depósitos y retiros con Arquitectura Hexagonal, .NET Core y MS SQL Service Broker.' : 'Financial deposit/withdrawal system with Hexagonal Architecture, .NET Core and MS SQL Service Broker.'}</li>
                </ul>
                <div class="project-tags">
                    <span class="project-tag">.net core</span>
                    <span class="project-tag">c#</span>
                    <span class="project-tag">sql</span>
                    <span class="project-tag">hexagonal</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- SKILLS -->
<section class="section" id="skills">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">04</span>
            <h2 class="section-title">Skills</h2>
        </div>
        <div class="skills-grid">
            {skillSections.map(section => (
                <div class="skill-group">
                    <h3 class="skill-group-title">{section.title}</h3>
                    <div class="skill-tags">
                        {section.items.map((item: string) => (
                            <span class="skill-pill">{item}</span>
                        ))}
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<!-- SERVICES -->
<section class="section" id="services">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">05</span>
            <h2 class="section-title">{locale === 'es' ? '\u00bfQu\u00e9 puedo construir?' : 'What can I build?'}</h2>
        </div>
        <div class="services-grid">
            {services.map(s => (
                <div class="service-card">
                    <span class="service-icon">{s.icon}</span>
                    <h3 class="service-label">{s.label}</h3>
                    <p class="service-desc">{s.desc}</p>
                </div>
            ))}
        </div>
        <div class="services-cta">
            <p>{locale === 'es' ? '\u00bfNecesitas alg\u00fan tipo de desarrollo a la medida?' : 'Need custom software development?'}</p>
            <button id="cta-email-btn" class="btn-primary cta-btn">{locale === 'es' ? 'Cont\u00e1ctame' : 'Contact me'}</button>
        </div>
    </div>
</section>

<!-- CONTACT -->
<section class="section section-contact" id="contact">
    <div class="container">
        <div class="contact-inner">
            <div class="contact-left">
                <span class="section-tag">06</span>
                <h2 class="contact-title">
                    {locale === 'es' ? "¿Trabajamos\njuntos?" : "Let's work\ntogether."}
                </h2>
                <p class="contact-sub">
                    {locale === 'es'
                        ? 'Disponible para proyectos freelance, consultoría y posiciones remotas.'
                        : 'Available for freelance projects, consulting, and remote positions.'}
                </p>
            </div>
            <div class="contact-links">

                <!-- Email -->
                <button class="contact-link contact-email-btn" id="email-btn">
                    <span class="contact-link-left">
                        <svg class="contact-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,12 2,6"/></svg>
                        <span class="contact-link-label">Email</span>
                    </span>
                    <span class="contact-link-value">{email}</span>
                </button>

                <!-- LinkedIn -->
                <a href={`https://linkedin.com/in/${linkedin}`} target="_blank" class="contact-link">
                    <span class="contact-link-left">
                        <svg class="contact-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                        <span class="contact-link-label">LinkedIn</span>
                    </span>
                    <span class="contact-link-value">in/{linkedin}</span>
                </a>

                <!-- GitHub -->
                <a href={`https://github.com/${github}`} target="_blank" class="contact-link">
                    <span class="contact-link-left">
                        <svg class="contact-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
                        <span class="contact-link-label">GitHub</span>
                    </span>
                    <span class="contact-link-value">{github}</span>
                </a>

                <!-- Phone -->
                <a href={`tel:${phone}`} class="contact-link">
                    <span class="contact-link-left">
                        <svg class="contact-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.67A2 2 0 012 .18h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 7.91a16 16 0 006.72 6.72l1.29-1.29a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
                        <span class="contact-link-label">{locale === 'es' ? 'Teléfono' : 'Phone'}</span>
                    </span>
                    <span class="contact-link-value">{phone}</span>
                </a>

                <!-- WhatsApp -->
                <a href={`https://wa.me/${phone.replace(/[^0-9]/g,'')}`} target="_blank" rel="noopener" class="contact-link whatsapp-link">
                    <span class="contact-link-left">
                        <svg class="contact-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                        <span class="contact-link-label">WhatsApp</span>
                    </span>
                    <span class="contact-link-value whatsapp-val">{locale === 'es' ? 'Chateame' : 'Chat with me'}</span>
                </a>

            </div>
        </div>
    </div>
</section>

<!-- EMAIL MODAL -->
<div class="modal-overlay" id="email-modal">
    <div class="modal-box">
        <button class="modal-close" id="modal-close">×</button>
        <h3 class="modal-title">{locale === 'es' ? 'Envíame un mensaje' : 'Send me a message'}</h3>
        <p class="modal-sub">{locale === 'es' ? 'Te responderé lo antes posible.' : 'I will get back to you as soon as possible.'}</p>
        <form class="email-form" id="email-form">
            <div class="form-field">
                <label>{locale === 'es' ? 'Tu nombre' : 'Your name'}</label>
                <input type="text" name="name" required placeholder={locale === 'es' ? 'Juan Pérez' : 'John Smith'} />
            </div>
            <div class="form-field">
                <label>Email</label>
                <input type="email" name="email" required placeholder="you@email.com" />
            </div>
            <div class="form-field">
                <label>{locale === 'es' ? 'Mensaje' : 'Message'}</label>
                <textarea name="message" rows="4" required placeholder={locale === 'es' ? '\u00bfEn qué puedo ayudarte?' : 'What can I help you with?'}></textarea>
            </div>
            <button type="submit" class="form-submit">
                {locale === 'es' ? 'Enviar mensaje' : 'Send message'}
            </button>
            <div class="form-success" id="form-success" style="display:none">
                ✓ {locale === 'es' ? 'Mensaje enviado. ¡Gracias!' : 'Message sent. Thank you!'}
            </div>
        </form>
    </div>
</div>

<footer class="footer">
    <div class="container">
        <span>{name} © {new Date().getFullYear()}</span>
        <a href="/resume">{locale === 'es' ? 'Ver Resume' : 'View Resume'} →</a>
    </div>
</footer>

</body>
</html>

<style>
/* ── Reset & Base ─────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
    --bg: #080c14;
    --bg2: #0d1220;
    --bg3: #111827;
    --cyan: #00e5ff;
    --cyan2: #00bcd4;
    --cyan-dim: rgba(0,229,255,0.08);
    --white: #f0f4ff;
    --muted: #8892a4;
    --border: rgba(0,229,255,0.15);
    --font-display: 'Bebas Neue', sans-serif;
    --font-body: 'DM Sans', sans-serif;
    --font-mono: 'JetBrains Mono', monospace;
}

html { scroll-behavior: smooth; }

body {
    background: var(--bg);
    color: var(--white);
    font-family: var(--font-body);
    font-weight: 300;
    line-height: 1.6;
    overflow-x: hidden;
}

.container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
}

/* ── Noise texture overlay ───────────────────────────── */
body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 0;
    opacity: 0.4;
}

/* ── Nav ─────────────────────────────────────────────── */
.nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 2.5rem;
    background: rgba(8,12,20,0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    transition: all 0.3s;
}

.nav-logo {
    font-family: var(--font-display);
    font-size: 1.3rem;
    letter-spacing: 0.1em;
    color: var(--cyan);
}

.nav-links {
    display: flex;
    list-style: none;
    gap: 2rem;
    align-items: center;
}

.nav-links a {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    transition: color 0.2s;
}

.nav-links a:hover { color: var(--cyan); }

.nav-cta {
    color: var(--cyan) !important;
    border: 1px solid var(--border) !important;
    padding: 0.4rem 1rem;
    border-radius: 4px;
    transition: background 0.2s !important;
    cursor: pointer;
}
.nav-cta:hover { background: var(--cyan-dim) !important; }

/* Resume dropdown */
.nav-resume-wrap {
    position: relative;
    list-style: none;
}
.nav-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 0.5rem);
    right: 0;
    background: rgba(13,18,32,0.97);
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    min-width: 140px;
    backdrop-filter: blur(12px);
    z-index: 200;
    padding-top: 0.5rem; /* invisible bridge between trigger and dropdown */
    margin-top: -0.5rem;
}
.nav-dropdown a {
    display: block;
    padding: 0.6rem 1rem;
    color: var(--white) !important;
    font-size: 0.82rem !important;
    text-transform: none !important;
    border: none !important;
    transition: background 0.15s !important;
}
.nav-dropdown a:hover { background: var(--cyan-dim) !important; color: var(--cyan) !important; }
.nav-resume-wrap:hover .nav-dropdown { display: block; }
.nav-resume-wrap .nav-dropdown:hover { display: block; }

/* ── Hero ────────────────────────────────────────────── */
.hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 8rem 2.5rem 4rem;
    position: relative;
    overflow: hidden;
}

.hero::before {
    content: '';
    position: absolute;
    top: -20%;
    right: -10%;
    width: 700px;
    height: 700px;
    background: radial-gradient(circle, rgba(0,229,255,0.06) 0%, transparent 70%);
    pointer-events: none;
}

.hero-grid {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    width: 100%;
}

.hero-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--cyan);
    letter-spacing: 0.15em;
    margin-bottom: 1rem;
    opacity: 0;
    animation: fadeUp 0.6s 0.1s forwards;
}

.hero-name {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    letter-spacing: 0.05em;
    color: var(--white);
    line-height: 1;
    margin-bottom: 0.5rem;
    opacity: 0;
    animation: fadeUp 0.6s 0.2s forwards;
}

.hero-role {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.2rem);
    letter-spacing: 0.08em;
    line-height: 1.05;
    color: var(--muted);
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: fadeUp 0.6s 0.3s forwards;
}

.hero-role-accent { color: var(--cyan); }

.hero-bio {
    font-size: 0.95rem;
    color: var(--muted);
    max-width: 480px;
    line-height: 1.7;
    margin-bottom: 2rem;
    opacity: 0;
    animation: fadeUp 0.6s 0.4s forwards;
}

.hero-actions {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
    opacity: 0;
    animation: fadeUp 0.6s 0.5s forwards;
}

.btn-primary {
    background: var(--cyan);
    color: var(--bg);
    padding: 0.75rem 1.75rem;
    border-radius: 4px;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    transition: opacity 0.2s, transform 0.2s;
}

.btn-primary:hover { opacity: 0.85; transform: translateY(-2px); }

.btn-secondary {
    border: 1px solid var(--border);
    color: var(--white);
    padding: 0.75rem 1.75rem;
    border-radius: 4px;
    text-decoration: none;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    transition: border-color 0.2s, color 0.2s, transform 0.2s;
}

.btn-secondary:hover { border-color: var(--cyan); color: var(--cyan); transform: translateY(-2px); }

.hero-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    opacity: 0;
    animation: fadeUp 0.6s 0.6s forwards;
}

.hero-tags span {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--muted);
    border: 1px solid rgba(255,255,255,0.08);
    padding: 0.25rem 0.6rem;
    border-radius: 3px;
    letter-spacing: 0.05em;
}

/* ── Code Window ─────────────────────────────────────── */
.hero-visual {
    position: relative;
    opacity: 0;
    animation: fadeLeft 0.8s 0.4s forwards;
}

.code-window {
    background: #0d1220;
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 0 60px rgba(0,229,255,0.08), 0 20px 60px rgba(0,0,0,0.5);
}

.code-window-bar {
    background: #161e2e;
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border-bottom: 1px solid var(--border);
}

.dot {
    width: 12px; height: 12px;
    border-radius: 50%;
}
.dot.red { background: #ff5f57; }
.dot.yellow { background: #febc2e; }
.dot.green { background: #28c840; }

.code-window-title {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--muted);
    margin-left: 0.5rem;
}

.code-content {
    padding: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 1.8;
    white-space: pre;
    overflow-x: auto;
}

.c-keyword { color: #c792ea; }
.c-var { color: #82aaff; }
.c-str { color: #c3e88d; }
.c-num { color: #f78c6c; }
.c-punct { color: var(--muted); }
.c-bracket { color: var(--cyan); }

.hero-glow {
    position: absolute;
    bottom: -40px;
    right: -40px;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(0,229,255,0.1) 0%, transparent 70%);
    pointer-events: none;
    z-index: -1;
}

/* ── Scroll indicator ────────────────────────────────── */
.hero-scroll {
    display: flex;
    align-items: center;
    gap: 1rem;
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--muted);
    letter-spacing: 0.15em;
    text-transform: uppercase;
}

.scroll-line {
    width: 40px;
    height: 1px;
    background: var(--muted);
    position: relative;
    overflow: hidden;
}

.scroll-line::after {
    content: '';
    position: absolute;
    left: -100%;
    top: 0;
    width: 100%;
    height: 100%;
    background: var(--cyan);
    animation: scrollAnim 2s ease-in-out infinite;
}

/* ── Highlights ──────────────────────────────────────── */
.highlights {
    padding: 4rem 2.5rem;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background: var(--bg2);
}

.highlights-grid {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
}

.highlight-card {
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--bg3);
    transition: border-color 0.3s, transform 0.3s;
    cursor: default;
}

.highlight-card:hover {
    border-color: var(--cyan);
    transform: translateY(-4px);
}

.highlight-icon { font-size: 1.5rem; margin-bottom: 0.75rem; }

.highlight-value {
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--cyan);
    letter-spacing: 0.05em;
    line-height: 1;
    margin-bottom: 0.25rem;
}

.highlight-label {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--white);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.25rem;
}

.highlight-sub {
    font-size: 0.75rem;
    color: var(--muted);
    font-family: var(--font-mono);
}

/* ── Sections ────────────────────────────────────────── */
.section {
    padding: 6rem 2.5rem;
}

.section-alt {
    background: var(--bg2);
}

.section-header {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 3rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
}

.section-tag {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--cyan);
    letter-spacing: 0.15em;
}

.section-title {
    font-family: var(--font-display);
    font-size: 2.5rem;
    letter-spacing: 0.05em;
    color: var(--white);
}

/* ── Timeline ────────────────────────────────────────── */
.timeline {
    position: relative;
    padding-left: 2rem;
}

.timeline::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 1px;
    background: linear-gradient(to bottom, var(--cyan), transparent);
}

.timeline-item {
    position: relative;
    margin-bottom: 3rem;
    padding-left: 2rem;
}

.timeline-dot {
    position: absolute;
    left: -2.4rem;
    top: 0.4rem;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--cyan);
    box-shadow: 0 0 12px var(--cyan);
}

.timeline-meta {
    display: flex;
    gap: 1rem;
    margin-bottom: 0.5rem;
}

.timeline-period {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--cyan);
    letter-spacing: 0.1em;
}

.timeline-location {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--muted);
}

.timeline-role {
    font-family: var(--font-display);
    font-size: 1.4rem;
    letter-spacing: 0.05em;
    color: var(--white);
    margin-bottom: 0.25rem;
}

.timeline-company {
    font-size: 0.85rem;
    color: var(--cyan2);
    margin-bottom: 0.75rem;
    font-weight: 500;
}

.timeline-bullets {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
}

.timeline-bullets li {
    font-size: 0.875rem;
    color: var(--muted);
    padding-left: 1rem;
    position: relative;
    line-height: 1.6;
}

.timeline-bullets li::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--cyan);
    font-size: 0.7rem;
    top: 0.15rem;
}

.timeline-bullets strong { color: var(--white); font-weight: 500; }

/* ── Projects ────────────────────────────────────────── */
.projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
}

.project-card {
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.75rem;
    transition: border-color 0.3s, transform 0.3s;
    position: relative;
    overflow: hidden;
}

.project-card:hover {
    border-color: var(--cyan);
    transform: translateY(-6px);
}

.project-card-header {
    margin-bottom: 1rem;
}

.project-number {
    font-family: var(--font-display);
    font-size: 3rem;
    color: rgba(0,229,255,0.1);
    line-height: 1;
    letter-spacing: 0.05em;
}

.project-card-glow {
    position: absolute;
    top: 0; right: 0;
    width: 150px;
    height: 150px;
    background: radial-gradient(circle, rgba(0,229,255,0.05) 0%, transparent 70%);
    pointer-events: none;
}

.project-name {
    font-family: var(--font-display);
    font-size: 1.2rem;
    letter-spacing: 0.05em;
    color: var(--white);
    margin-bottom: 0.75rem;
}

.project-bullets {
    list-style: none;
    margin-bottom: 1rem;
}

.project-bullets li {
    font-size: 0.8rem;
    color: var(--muted);
    line-height: 1.6;
    padding-left: 0.75rem;
    position: relative;
    margin-bottom: 0.35rem;
}

.project-bullets li::before {
    content: '·';
    position: absolute;
    left: 0;
    color: var(--cyan);
}

.project-bullets strong { color: var(--white); font-weight: 500; }

.project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
}

.project-tag {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--cyan2);
    border: 1px solid rgba(0,188,212,0.3);
    padding: 0.2rem 0.5rem;
    border-radius: 3px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

/* ── Skills ──────────────────────────────────────────── */
.skills-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
}

.skill-group-title {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--cyan);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 0.75rem;
}

.skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
}

.skill-pill {
    font-size: 0.8rem;
    color: var(--white);
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    transition: border-color 0.2s, color 0.2s;
}

.skill-pill:hover {
    border-color: var(--cyan);
    color: var(--cyan);
}

/* ── Contact ─────────────────────────────────────────── */
.section-contact {
    background: var(--bg2);
    border-top: 1px solid var(--border);
    position: relative;
    overflow: hidden;
    transition: box-shadow 0.5s ease;
}

.section-contact.glow-active {
    box-shadow: inset 0 0 120px rgba(0,229,255,0.07), inset 0 0 40px rgba(0,229,255,0.05);
}

.section-contact.glow-active::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 60% at 50% 50%, rgba(0,229,255,0.06) 0%, transparent 70%);
    pointer-events: none;
    animation: contactGlowPulse 2s ease-in-out;
    z-index: 0;
}

@keyframes contactGlowPulse {
    0%   { opacity: 0; }
    20%  { opacity: 1; }
    80%  { opacity: 1; }
    100% { opacity: 0; }
}

.contact-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    position: relative;
    z-index: 1;
}

.contact-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    letter-spacing: 0.05em;
    line-height: 1;
    white-space: pre-line;
    margin: 0.75rem 0 1rem;
    color: var(--white);
}

.contact-sub {
    color: var(--muted);
    font-size: 0.9rem;
    max-width: 320px;
    margin-bottom: 1.5rem;
}

.contact-links {
    display: flex;
    flex-direction: column;
    gap: 1px;
}

.contact-link {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.1rem 0.75rem;
    border-radius: 6px;
    margin-bottom: 2px;
    text-decoration: none;
    background: rgba(255,255,255,0.02);
    border: 1px solid transparent;
    transition: background 0.2s, border-color 0.2s, transform 0.2s, padding-left 0.2s;
}

.contact-link:hover {
    background: rgba(0,229,255,0.04);
    border-color: var(--border);
    padding-left: 1.1rem;
    transform: translateX(4px);
}
.contact-link:hover .contact-link-value { color: var(--cyan); }

.contact-link-left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
}

.contact-icon {
    width: 18px;
    height: 18px;
    color: var(--cyan);
    opacity: 0.7;
    flex-shrink: 0;
    transition: opacity 0.2s;
}

.contact-link:hover .contact-icon { opacity: 1; }

.contact-link-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
}

.contact-link-value {
    font-size: 0.85rem;
    color: var(--white);
    transition: color 0.2s;
    font-family: var(--font-mono);
}

/* ── Footer ──────────────────────────────────────────── */
.footer {
    padding: 1.5rem 2.5rem;
    border-top: 1px solid var(--border);
}

.footer .container {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.footer span {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--muted);
}

.footer a {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--cyan);
    text-decoration: none;
    transition: opacity 0.2s;
}

.footer a:hover { opacity: 0.7; }

/* ── Animations ──────────────────────────────────────── */
@keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
}

@keyframes fadeLeft {
    from { opacity: 0; transform: translateX(30px); }
    to   { opacity: 1; transform: translateX(0); }
}

@keyframes scrollAnim {
    0%   { left: -100%; }
    50%  { left: 0%; }
    100% { left: 100%; }
}

/* ── Responsive ──────────────────────────────────────── */
@media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; }
    .hero-visual { display: none; }
    .highlights-grid { grid-template-columns: repeat(2, 1fr); }
    .projects-grid { grid-template-columns: 1fr; }
    .skills-grid { grid-template-columns: 1fr; }
    .services-grid { grid-template-columns: repeat(2, 1fr); }
    .services-cta { flex-direction: column; text-align: center; }
    .contact-inner { grid-template-columns: 1fr; gap: 2rem; }
    .nav-links { display: none; }
}

/* ── Services ─────────────────────────────────── */
.services-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-bottom: 2.5rem;
}
.service-card {
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.25rem;
    transition: border-color 0.3s, transform 0.3s;
}
.service-card:hover { border-color: var(--cyan); transform: translateY(-3px); }
.service-icon { font-size: 1.5rem; display: block; margin-bottom: 0.6rem; }
.service-label {
    font-family: var(--font-display);
    font-size: 1rem;
    letter-spacing: 0.05em;
    color: var(--white);
    margin-bottom: 0.4rem;
}
.service-desc { font-size: 0.78rem; color: var(--muted); line-height: 1.6; }
.services-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: 1.5rem 2rem;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 8px;
}
.services-cta p {
    font-size: 1rem;
    color: var(--white);
    font-family: var(--font-display);
    letter-spacing: 0.03em;
}

/* ── WhatsApp link ─────────────────────────────── */
.whatsapp-link:hover .whatsapp-val { color: #25d366 !important; }
.whatsapp-link:hover { border-color: #25d366 !important; }

/* ── Email button (contact-link as button) ────────── */
.contact-email-btn {
    width: 100%;
    text-align: left;
    background: none;
    cursor: pointer;
    font-family: inherit;
}

/* ── Modal ──────────────────────────────────────── */
.modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.7);
    backdrop-filter: blur(4px);
    z-index: 9999;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 1rem;
}
.modal-overlay.open { display: flex; }

.modal-box {
    background: #0d1220;
    border: 1px solid rgba(0,229,255,0.2);
    border-radius: 12px;
    padding: 2rem;
    width: 100%;
    max-width: 480px;
    position: relative;
    animation: fadeUp 0.25s forwards;
}

.modal-close {
    position: absolute;
    top: 1rem; right: 1rem;
    background: none;
    border: none;
    color: var(--muted);
    font-size: 1.4rem;
    cursor: pointer;
    line-height: 1;
    transition: color 0.2s;
}
.modal-close:hover { color: var(--white); }

.modal-title {
    font-family: var(--font-display);
    font-size: 1.6rem;
    letter-spacing: 0.05em;
    color: var(--white);
    margin-bottom: 0.4rem;
}
.modal-sub { font-size: 0.85rem; color: var(--muted); margin-bottom: 1.5rem; }

.email-form { display: flex; flex-direction: column; gap: 1rem; }

.form-field { display: flex; flex-direction: column; gap: 0.3rem; }
.form-field label {
    font-size: 0.7rem;
    color: var(--muted);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.05em;
}
.form-field input,
.form-field textarea {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 6px;
    padding: 0.6rem 0.85rem;
    color: var(--white);
    font-family: var(--font-body);
    font-size: 0.9rem;
    outline: none;
    transition: border-color 0.2s;
    resize: vertical;
}
.form-field input:focus,
.form-field textarea:focus { border-color: var(--cyan); }
.form-field input::placeholder,
.form-field textarea::placeholder { color: rgba(255,255,255,0.2); }

.form-submit {
    background: var(--cyan);
    color: var(--bg);
    border: none;
    border-radius: 6px;
    padding: 0.75rem;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    font-family: var(--font-body);
    transition: opacity 0.2s;
    margin-top: 0.25rem;
}
.form-submit:hover:not(:disabled) { opacity: 0.85; }
.form-submit:disabled { opacity: 0.5; cursor: not-allowed; }

.form-success {
    text-align: center;
    color: #28c840;
    font-size: 0.9rem;
    padding: 0.5rem;
    border: 1px solid rgba(40,200,64,0.3);
    border-radius: 6px;
    background: rgba(40,200,64,0.08);
}
</style>

<script>
    // Sticky nav shadow on scroll
    const nav = document.getElementById('nav')
    window.addEventListener('scroll', () => {
        nav?.classList.toggle('scrolled', window.scrollY > 50)
    })

    // "Contact me" CTA → glow effect on #contact section
    const ctaEmailBtn = document.getElementById('cta-email-btn')
    const contactSection = document.querySelector('.section-contact') as HTMLElement | null
    ctaEmailBtn?.addEventListener('click', () => {
        contactSection?.scrollIntoView({ behavior: 'smooth' })
        setTimeout(() => {
            contactSection?.classList.add('glow-active')
            setTimeout(() => contactSection?.classList.remove('glow-active'), 2200)
        }, 500)
    })

    // Email modal
    const modal = document.getElementById('email-modal')!
    const emailBtn = document.getElementById('email-btn')!
    const closeBtn = document.getElementById('modal-close')!
    const form = document.getElementById('email-form') as HTMLFormElement
    const successMsg = document.getElementById('form-success')!

    emailBtn?.addEventListener('click', () => modal.classList.add('open'))
    closeBtn?.addEventListener('click', () => modal.classList.remove('open'))
    modal?.addEventListener('click', (e) => {
        if (e.target === modal) modal.classList.remove('open')
    })
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') modal.classList.remove('open')
    })

    form?.addEventListener('submit', (e) => {
        e.preventDefault()
        const data = new FormData(form)
        const name = data.get('name')
        const email = data.get('email')
        const message = data.get('message')
        // Abre cliente de correo con los datos prellenados
        const subject = encodeURIComponent(`Portfolio Contact - ${name}`)
        const body = encodeURIComponent(`Name: ${name}\nEmail: ${email}\n\n${message}`)
        window.location.href = `mailto:${emailBtn.querySelector('.contact-link-value')?.textContent?.trim()}?subject=${subject}&body=${body}`
        successMsg.style.display = 'block'
        const submitBtn = form.querySelector('.form-submit') as HTMLButtonElement
        submitBtn.disabled = true
        setTimeout(() => {
            modal.classList.remove('open')
            form.reset()
            successMsg.style.display = 'none'
            submitBtn.disabled = false
        }, 2500)
    })
</script>
