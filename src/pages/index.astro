---
import { getLocaleFromCookie, type Locale } from '@/i18n'
import { getPersonal, getExperienceDB, getProjectsDB, getSkillSectionsDB } from '@/lib/profile'
import LangToggle from '@/components/LangToggle.astro'

const cookieHeader = Astro.request.headers.get('cookie')
const locale: Locale = getLocaleFromCookie(cookieHeader)

const personal = await getPersonal(locale)
const experience = await getExperienceDB(locale)
const projects = await getProjectsDB(locale)
const skillSections = await getSkillSectionsDB()

const { name, title, email, phone, linkedin, github, location, bio } = personal

const highlights = locale === 'es'
    ? [
        { icon: '⚡', value: '14+', label: 'Años de Experiencia', sub: 'Fintech · E-commerce · Cloud' },
        { icon: '🏗️', value: 'LEAD', label: 'Líder Técnico & Mentor', sub: 'Premio a la Excelencia · OmegaTech' },
        { icon: '🔷', value: 'HEX', label: 'Arquitectura Hexagonal', sub: '.NET Core · OpenAPI · DDD' },
        { icon: '🤖', value: 'SDET', label: 'QA Automation Expert', sub: 'Appium · Selenium · Cucumber' },
    ]
    : [
        { icon: '⚡', value: '14+', label: 'Years of Experience', sub: 'Fintech · E-commerce · Cloud' },
        { icon: '🏗️', value: 'LEAD', label: 'Tech Lead & Mentor', sub: 'Award for Excellence · OmegaTech' },
        { icon: '🔷', value: 'HEX', label: 'Hexagonal Architecture', sub: '.NET Core · OpenAPI · DDD' },
        { icon: '🤖', value: 'SDET', label: 'QA Automation Expert', sub: 'Appium · Selenium · Cucumber' },
    ]
---

<!DOCTYPE html>
<html lang={locale}>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{name} — Portfolio</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
</head>
<body>

<LangToggle locale={locale} />

<!-- NAV -->
<nav class="nav" id="nav">
    <div class="nav-logo">{name.split(' ').slice(0,2).join(' ')}</div>
    <ul class="nav-links">
        <li><a href="#about">{locale === 'es' ? 'Sobre mí' : 'About'}</a></li>
        <li><a href="#experience">{locale === 'es' ? 'Experiencia' : 'Experience'}</a></li>
        <li><a href="#projects">{locale === 'es' ? 'Proyectos' : 'Projects'}</a></li>
        <li><a href="#skills">Skills</a></li>
        <li><a href="#contact">{locale === 'es' ? 'Contacto' : 'Contact'}</a></li>
        <li><a href="/resume" class="nav-cta">{locale === 'es' ? 'Ver Resume' : 'View Resume'}</a></li>
    </ul>
</nav>

<!-- HERO -->
<section class="hero" id="about">
    <div class="hero-grid">
        <div class="hero-content">
            <p class="hero-eyebrow">// {location}</p>
            <h1 class="hero-name">{name}</h1>
            <h2 class="hero-role">
                {locale === 'es' ? 'SENIOR FULL STACK' : 'SENIOR FULL STACK'}<br>
                <span class="hero-role-accent">ENGINEER &amp; SDET</span>
            </h2>
            <p class="hero-bio">{bio}</p>
            <div class="hero-actions">
                <a href="#projects" class="btn-primary">{locale === 'es' ? 'Ver Proyectos' : 'View Projects'}</a>
                <a href="#contact" class="btn-secondary">{locale === 'es' ? 'Contactar' : 'Contact'}</a>
            </div>
            <div class="hero-tags">
                <span>.NET Core</span><span>React</span><span>Node.js</span><span>MongoDB</span><span>Docker</span><span>TypeScript</span>
            </div>
        </div>
        <div class="hero-visual">
            <div class="code-window">
                <div class="code-window-bar">
                    <span class="dot red"></span><span class="dot yellow"></span><span class="dot green"></span>
                    <span class="code-window-title">profile.ts</span>
                </div>
                <pre class="code-content"><code><span class="c-keyword">const</span> <span class="c-var">dev</span> = <span class="c-bracket">&#123;</span>
  name<span class="c-punct">:</span> <span class="c-str">"{name.split(' ')[0]}"</span><span class="c-punct">,</span>
  role<span class="c-punct">:</span> <span class="c-str">"Full Stack + SDET"</span><span class="c-punct">,</span>
  years<span class="c-punct">:</span> <span class="c-num">14</span><span class="c-punct">,</span>
  stack<span class="c-punct">:</span> <span class="c-bracket">[</span>
    <span class="c-str">".NET Core"</span><span class="c-punct">,</span>
    <span class="c-str">"React"</span><span class="c-punct">,</span>
    <span class="c-str">"Node.js"</span><span class="c-punct">,</span>
    <span class="c-str">"TypeScript"</span>
  <span class="c-bracket">]</span><span class="c-punct">,</span>
  passion<span class="c-punct">:</span> <span class="c-str">"Clean Architecture"</span>
<span class="c-bracket">&#125;</span>

<span class="c-keyword">export default</span> dev<span class="c-punct">;</span></code></pre>
            </div>
            <div class="hero-glow"></div>
        </div>
    </div>
    <div class="hero-scroll">
        <span>scroll</span>
        <div class="scroll-line"></div>
    </div>
</section>

<!-- HIGHLIGHTS -->
<section class="highlights" id="highlights">
    <div class="container">
        <div class="highlights-grid">
            {highlights.map(h => (
                <div class="highlight-card">
                    <div class="highlight-icon">{h.icon}</div>
                    <div class="highlight-value">{h.value}</div>
                    <div class="highlight-label">{h.label}</div>
                    <div class="highlight-sub">{h.sub}</div>
                </div>
            ))}
        </div>
    </div>
</section>

<!-- EXPERIENCE -->
<section class="section" id="experience">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">02</span>
            <h2 class="section-title">{locale === 'es' ? 'Experiencia' : 'Experience'}</h2>
        </div>
        <div class="timeline">
            {experience.map((exp, i) => (
                <div class="timeline-item">
                    <div class="timeline-dot"></div>
                    <div class="timeline-content">
                        <div class="timeline-meta">
                            <span class="timeline-period">
                                {exp.startYear} — {exp.endYear ?? (locale === 'es' ? 'Presente' : 'Present')}
                            </span>
                            <span class="timeline-location">{exp.location}</span>
                        </div>
                        <h3 class="timeline-role">{exp.title}</h3>
                        <p class="timeline-company">{exp.name}</p>
                        <ul class="timeline-bullets">
                            {exp.bullets.slice(0, 3).map((b: string) => (
                                <li set:html={b.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')} />
                            ))}
                        </ul>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<!-- PROJECTS -->
<section class="section section-alt" id="projects">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">03</span>
            <h2 class="section-title">{locale === 'es' ? 'Proyectos Destacados' : 'Featured Projects'}</h2>
        </div>
        <div class="projects-grid">
            {projects.map((proj, i) => (
                <div class="project-card" data-index={i}>
                    <div class="project-card-header">
                        <div class="project-number">0{i + 1}</div>
                        <div class="project-card-glow"></div>
                    </div>
                    <h3 class="project-name">{proj.name}</h3>
                    <ul class="project-bullets">
                        {proj.bullets.slice(0, 2).map((b: string) => (
                            <li set:html={b.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')} />
                        ))}
                    </ul>
                    {proj.icons && proj.icons.length > 0 && (
                        <div class="project-tags">
                            {proj.icons.map((icon: string) => (
                                <span class="project-tag">{icon.split(':')[1]?.replace(/-icon$/, '') ?? icon}</span>
                            ))}
                        </div>
                    )}
                </div>
            ))}
            <!-- Extra project cards from resume -->
            <div class="project-card">
                <div class="project-card-header">
                    <div class="project-number">02</div>
                    <div class="project-card-glow"></div>
                </div>
                <h3 class="project-name">MINSA-SEIS Automation</h3>
                <ul class="project-bullets">
                    <li>{locale === 'es' ? 'Automatización de flujos de soporte técnico y creación masiva de usuarios en Active Directory.' : 'Automated support flows and bulk Active Directory user creation for MINSA health system.'}</li>
                </ul>
                <div class="project-tags">
                    <span class="project-tag">python</span>
                    <span class="project-tag">react</span>
                    <span class="project-tag">node</span>
                    <span class="project-tag">postgres</span>
                </div>
            </div>
            <div class="project-card">
                <div class="project-card-header">
                    <div class="project-number">03</div>
                    <div class="project-card-glow"></div>
                </div>
                <h3 class="project-name">MoneyStream — OmegaTech</h3>
                <ul class="project-bullets">
                    <li>{locale === 'es' ? 'Sistema financiero de depósitos y retiros con Arquitectura Hexagonal, .NET Core y MS SQL Service Broker.' : 'Financial deposit/withdrawal system with Hexagonal Architecture, .NET Core and MS SQL Service Broker.'}</li>
                </ul>
                <div class="project-tags">
                    <span class="project-tag">.net core</span>
                    <span class="project-tag">c#</span>
                    <span class="project-tag">sql</span>
                    <span class="project-tag">hexagonal</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- SKILLS -->
<section class="section" id="skills">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">04</span>
            <h2 class="section-title">Skills</h2>
        </div>
        <div class="skills-grid">
            {skillSections.map(section => (
                <div class="skill-group">
                    <h3 class="skill-group-title">{section.title}</h3>
                    <div class="skill-tags">
                        {section.items.map((item: string) => (
                            <span class="skill-pill">{item}</span>
                        ))}
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<!-- CONTACT -->
<section class="section section-contact" id="contact">
    <div class="container">
        <div class="contact-inner">
            <div class="contact-left">
                <span class="section-tag">05</span>
                <h2 class="contact-title">
                    {locale === 'es' ? "¿Trabajamos\njuntos?" : "Let's work\ntogether."}
                </h2>
                <p class="contact-sub">
                    {locale === 'es'
                        ? 'Disponible para proyectos freelance, consultoría y posiciones remotas.'
                        : 'Available for freelance projects, consulting, and remote positions.'}
                </p>
            </div>
            <div class="contact-links">
                <a href={`mailto:${email}`} class="contact-link">
                    <span class="contact-link-label">Email</span>
                    <span class="contact-link-value">{email}</span>
                </a>
                <a href={`https://linkedin.com/in/${linkedin}`} target="_blank" class="contact-link">
                    <span class="contact-link-label">LinkedIn</span>
                    <span class="contact-link-value">in/{linkedin}</span>
                </a>
                <a href={`https://github.com/${github}`} target="_blank" class="contact-link">
                    <span class="contact-link-label">GitHub</span>
                    <span class="contact-link-value">{github}</span>
                </a>
                <a href={`tel:${phone}`} class="contact-link">
                    <span class="contact-link-label">{locale === 'es' ? 'Teléfono' : 'Phone'}</span>
                    <span class="contact-link-value">{phone}</span>
                </a>
            </div>
        </div>
    </div>
</section>

<footer class="footer">
    <div class="container">
        <span>{name} © {new Date().getFullYear()}</span>
        <a href="/resume">{locale === 'es' ? 'Ver Resume' : 'View Resume'} →</a>
    </div>
</footer>

</body>
</html>

<style>
/* ── Reset & Base ─────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
    --bg: #080c14;
    --bg2: #0d1220;
    --bg3: #111827;
    --cyan: #00e5ff;
    --cyan2: #00bcd4;
    --cyan-dim: rgba(0,229,255,0.08);
    --white: #f0f4ff;
    --muted: #8892a4;
    --border: rgba(0,229,255,0.15);
    --font-display: 'Bebas Neue', sans-serif;
    --font-body: 'DM Sans', sans-serif;
    --font-mono: 'JetBrains Mono', monospace;
}

html { scroll-behavior: smooth; }

body {
    background: var(--bg);
    color: var(--white);
    font-family: var(--font-body);
    font-weight: 300;
    line-height: 1.6;
    overflow-x: hidden;
}

.container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
}

/* ── Noise texture overlay ───────────────────────────── */
body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 0;
    opacity: 0.4;
}

/* ── Nav ─────────────────────────────────────────────── */
.nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 2.5rem;
    background: rgba(8,12,20,0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    transition: all 0.3s;
}

.nav-logo {
    font-family: var(--font-display);
    font-size: 1.3rem;
    letter-spacing: 0.1em;
    color: var(--cyan);
}

.nav-links {
    display: flex;
    list-style: none;
    gap: 2rem;
    align-items: center;
}

.nav-links a {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    transition: color 0.2s;
}

.nav-links a:hover { color: var(--cyan); }

.nav-cta {
    color: var(--cyan) !important;
    border: 1px solid var(--border) !important;
    padding: 0.4rem 1rem;
    border-radius: 4px;
    transition: background 0.2s !important;
}

.nav-cta:hover { background: var(--cyan-dim) !important; }

/* ── Hero ────────────────────────────────────────────── */
.hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 8rem 2.5rem 4rem;
    position: relative;
    overflow: hidden;
}

.hero::before {
    content: '';
    position: absolute;
    top: -20%;
    right: -10%;
    width: 700px;
    height: 700px;
    background: radial-gradient(circle, rgba(0,229,255,0.06) 0%, transparent 70%);
    pointer-events: none;
}

.hero-grid {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    width: 100%;
}

.hero-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--cyan);
    letter-spacing: 0.15em;
    margin-bottom: 1rem;
    opacity: 0;
    animation: fadeUp 0.6s 0.1s forwards;
}

.hero-name {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    letter-spacing: 0.05em;
    color: var(--white);
    line-height: 1;
    margin-bottom: 0.5rem;
    opacity: 0;
    animation: fadeUp 0.6s 0.2s forwards;
}

.hero-role {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.2rem);
    letter-spacing: 0.08em;
    line-height: 1.05;
    color: var(--muted);
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: fadeUp 0.6s 0.3s forwards;
}

.hero-role-accent { color: var(--cyan); }

.hero-bio {
    font-size: 0.95rem;
    color: var(--muted);
    max-width: 480px;
    line-height: 1.7;
    margin-bottom: 2rem;
    opacity: 0;
    animation: fadeUp 0.6s 0.4s forwards;
}

.hero-actions {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
    opacity: 0;
    animation: fadeUp 0.6s 0.5s forwards;
}

.btn-primary {
    background: var(--cyan);
    color: var(--bg);
    padding: 0.75rem 1.75rem;
    border-radius: 4px;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    transition: opacity 0.2s, transform 0.2s;
}

.btn-primary:hover { opacity: 0.85; transform: translateY(-2px); }

.btn-secondary {
    border: 1px solid var(--border);
    color: var(--white);
    padding: 0.75rem 1.75rem;
    border-radius: 4px;
    text-decoration: none;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    transition: border-color 0.2s, color 0.2s, transform 0.2s;
}

.btn-secondary:hover { border-color: var(--cyan); color: var(--cyan); transform: translateY(-2px); }

.hero-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    opacity: 0;
    animation: fadeUp 0.6s 0.6s forwards;
}

.hero-tags span {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--muted);
    border: 1px solid rgba(255,255,255,0.08);
    padding: 0.25rem 0.6rem;
    border-radius: 3px;
    letter-spacing: 0.05em;
}

/* ── Code Window ─────────────────────────────────────── */
.hero-visual {
    position: relative;
    opacity: 0;
    animation: fadeLeft 0.8s 0.4s forwards;
}

.code-window {
    background: #0d1220;
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 0 60px rgba(0,229,255,0.08), 0 20px 60px rgba(0,0,0,0.5);
}

.code-window-bar {
    background: #161e2e;
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border-bottom: 1px solid var(--border);
}

.dot {
    width: 12px; height: 12px;
    border-radius: 50%;
}
.dot.red { background: #ff5f57; }
.dot.yellow { background: #febc2e; }
.dot.green { background: #28c840; }

.code-window-title {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--muted);
    margin-left: 0.5rem;
}

.code-content {
    padding: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 1.8;
    white-space: pre;
    overflow-x: auto;
}

.c-keyword { color: #c792ea; }
.c-var { color: #82aaff; }
.c-str { color: #c3e88d; }
.c-num { color: #f78c6c; }
.c-punct { color: var(--muted); }
.c-bracket { color: var(--cyan); }

.hero-glow {
    position: absolute;
    bottom: -40px;
    right: -40px;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(0,229,255,0.1) 0%, transparent 70%);
    pointer-events: none;
    z-index: -1;
}

/* ── Scroll indicator ────────────────────────────────── */
.hero-scroll {
    display: flex;
    align-items: center;
    gap: 1rem;
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--muted);
    letter-spacing: 0.15em;
    text-transform: uppercase;
}

.scroll-line {
    width: 40px;
    height: 1px;
    background: var(--muted);
    position: relative;
    overflow: hidden;
}

.scroll-line::after {
    content: '';
    position: absolute;
    left: -100%;
    top: 0;
    width: 100%;
    height: 100%;
    background: var(--cyan);
    animation: scrollAnim 2s ease-in-out infinite;
}

/* ── Highlights ──────────────────────────────────────── */
.highlights {
    padding: 4rem 2.5rem;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background: var(--bg2);
}

.highlights-grid {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
}

.highlight-card {
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--bg3);
    transition: border-color 0.3s, transform 0.3s;
    cursor: default;
}

.highlight-card:hover {
    border-color: var(--cyan);
    transform: translateY(-4px);
}

.highlight-icon { font-size: 1.5rem; margin-bottom: 0.75rem; }

.highlight-value {
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--cyan);
    letter-spacing: 0.05em;
    line-height: 1;
    margin-bottom: 0.25rem;
}

.highlight-label {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--white);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.25rem;
}

.highlight-sub {
    font-size: 0.75rem;
    color: var(--muted);
    font-family: var(--font-mono);
}

/* ── Sections ────────────────────────────────────────── */
.section {
    padding: 6rem 2.5rem;
}

.section-alt {
    background: var(--bg2);
}

.section-header {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 3rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
}

.section-tag {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--cyan);
    letter-spacing: 0.15em;
}

.section-title {
    font-family: var(--font-display);
    font-size: 2.5rem;
    letter-spacing: 0.05em;
    color: var(--white);
}

/* ── Timeline ────────────────────────────────────────── */
.timeline {
    position: relative;
    padding-left: 2rem;
}

.timeline::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 1px;
