---
import CmsLayout from '@/layouts/CmsLayout.astro'
import { connectDB } from '@/lib/mongodb'
import { Visit } from '@/lib/models/Visit'

await connectDB()

const now = new Date()
const todayStart   = new Date(now); todayStart.setHours(0,0,0,0)
const weekStart    = new Date(now.getTime() - 7  * 24 * 60 * 60 * 1000)
const monthStart   = new Date(now.getTime() - 30 * 24 * 60 * 60 * 1000)

const [
    totalVisits, visitsToday, visitsWeek, visitsMonth,
    portfolioTotal, resumeTotal, downloads,
    last30Days, recentVisits
] = await Promise.all([
    Visit.countDocuments({}),
    Visit.countDocuments({ timestamp: { $gte: todayStart } }),
    Visit.countDocuments({ timestamp: { $gte: weekStart } }),
    Visit.countDocuments({ timestamp: { $gte: monthStart } }),
    Visit.countDocuments({ page: '/' }),
    Visit.countDocuments({ page: '/resume' }),
    Visit.countDocuments({ action: 'download' }),
    // Group by day for chart (last 30 days)
    Visit.aggregate([
        { $match: { timestamp: { $gte: monthStart } } },
        { $group: {
            _id: { $dateToString: { format: '%Y-%m-%d', date: '$timestamp' } },
            count: { $sum: 1 },
            portfolio: { $sum: { $cond: [{ $eq: ['$page', '/'] }, 1, 0] } },
            resume:    { $sum: { $cond: [{ $eq: ['$page', '/resume'] }, 1, 0] } },
        }},
        { $sort: { _id: 1 } }
    ]),
    // Recent visits
    Visit.find({})
        .sort({ timestamp: -1 })
        .limit(20)
        .lean()
])

// Fill missing days in chart
const chartData: {date: string, total: number, portfolio: number, resume: number}[] = []
for (let i = 29; i >= 0; i--) {
    const d = new Date(now.getTime() - i * 24 * 60 * 60 * 1000)
    const dateStr = d.toISOString().split('T')[0]
    const found = last30Days.find((r: any) => r._id === dateStr)
    chartData.push({
        date: dateStr,
        total: found?.count ?? 0,
        portfolio: found?.portfolio ?? 0,
        resume: found?.resume ?? 0,
    })
}

const maxCount = Math.max(...chartData.map(d => d.total), 1)
---

<CmsLayout title="Analytics" activeSection="visits">
<div class="page-header">
    <div>
        <h1 class="page-title">Analytics</h1>
        <p class="page-sub">Visit tracking for your portfolio and resume.</p>
    </div>
</div>

<!-- STATS GRID -->
<div class="stats-grid">
    <div class="stat-card accent">
        <div class="stat-label">Total Visits</div>
        <div class="stat-value">{totalVisits.toLocaleString()}</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Today</div>
        <div class="stat-value">{visitsToday}</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">This Week</div>
        <div class="stat-value">{visitsWeek}</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">This Month</div>
        <div class="stat-value">{visitsMonth}</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Portfolio <code>/</code></div>
        <div class="stat-value">{portfolioTotal}</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Resume <code>/resume</code></div>
        <div class="stat-value">{resumeTotal}</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Downloads</div>
        <div class="stat-value">{downloads}</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Avg / Day (30d)</div>
        <div class="stat-value">{(visitsMonth / 30).toFixed(1)}</div>
    </div>
</div>

<!-- CHART: Last 30 days -->
<div class="chart-card">
    <div class="chart-header">
        <h2 class="section-title">Last 30 Days</h2>
        <div class="chart-legend">
            <span class="legend-dot portfolio"></span> Portfolio
            <span class="legend-dot resume"></span> Resume
        </div>
    </div>
    <div class="chart-wrap">
        <div class="chart-bars">
            {chartData.map(d => (
                <div class="bar-col" title={`${d.date}: ${d.total} visits`}>
                    <div class="bar-stack" style={`height: ${(d.total / maxCount) * 100}%`}>
                        <div class="bar-resume"   style={`flex: ${d.resume}`}></div>
                        <div class="bar-portfolio" style={`flex: ${d.portfolio}`}></div>
                    </div>
                    <span class="bar-label">{d.date.slice(5)}</span>
                </div>
            ))}
        </div>
    </div>
</div>

<!-- PAGE SPLIT -->
<div class="split-grid">
    <div class="split-card">
        <h2 class="section-title">Page Split</h2>
        {totalVisits > 0 ? (
            <div class="donut-wrap">
                <div class="donut-bars">
                    <div class="donut-row">
                        <span class="donut-label">Portfolio <code>/</code></span>
                        <div class="donut-bar-track">
                            <div class="donut-bar portfolio" style={`width: ${(portfolioTotal/totalVisits*100).toFixed(1)}%`}></div>
                        </div>
                        <span class="donut-pct">{(portfolioTotal/totalVisits*100).toFixed(1)}%</span>
                    </div>
                    <div class="donut-row">
                        <span class="donut-label">Resume <code>/resume</code></span>
                        <div class="donut-bar-track">
                            <div class="donut-bar resume" style={`width: ${(resumeTotal/totalVisits*100).toFixed(1)}%`}></div>
                        </div>
                        <span class="donut-pct">{(resumeTotal/totalVisits*100).toFixed(1)}%</span>
                    </div>
                </div>
            </div>
        ) : (
            <p class="empty">No visits yet.</p>
        )}
    </div>

    <!-- RECENT VISITS -->
    <div class="split-card">
        <h2 class="section-title">Recent Visits</h2>
        <div class="recent-list">
            {recentVisits.length > 0 ? recentVisits.map((v: any) => (
                <div class="recent-row">
                    <span class={`page-badge ${v.page === '/' ? 'portfolio' : 'resume'}`}>
                        {v.page === '/' ? 'Portfolio' : 'Resume'}
                    </span>
                    <span class="recent-locale">{v.locale?.toUpperCase() ?? 'EN'}</span>
                    <span class="recent-time">
                        {new Date(v.timestamp).toLocaleString('en', { month:'short', day:'numeric', hour:'2-digit', minute:'2-digit' })}
                    </span>
                    {v.action === 'download' && <span class="download-badge">⬇ download</span>}
                </div>
            )) : (
                <p class="empty">No visits recorded yet.</p>
            )}
        </div>
    </div>
</div>

</CmsLayout>

<style>
.page-header {
    margin-bottom: 1.75rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
}
.page-title { font-size: 1.5rem; font-weight: 500; color: #f0f4ff; margin-bottom: 0.25rem; }
.page-sub { font-size: 0.85rem; color: #8892a4; }
.section-title { font-size: 0.8rem; color: #8892a4; text-transform: uppercase; letter-spacing: 0.08em; font-family: 'JetBrains Mono', monospace; margin-bottom: 1rem; }

/* Stats */
.stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.85rem;
    margin-bottom: 1.5rem;
}
.stat-card {
    background: #0d1220;
    border: 1px solid rgba(0,229,255,0.1);
    border-radius: 8px;
    padding: 1rem 1.1rem;
}
.stat-card.accent { border-color: rgba(0,229,255,0.35); }
.stat-label { font-size: 0.7rem; color: #8892a4; font-family: 'JetBrains Mono', monospace; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 0.4rem; }
.stat-label code { font-size: 0.65rem; color: #00e5ff; background: rgba(0,229,255,0.08); padding: 0.05rem 0.3rem; border-radius: 2px; }
.stat-value { font-size: 1.75rem; font-weight: 600; color: #00e5ff; line-height: 1; }

/* Chart */
.chart-card {
    background: #0d1220;
    border: 1px solid rgba(0,229,255,0.1);
    border-radius: 8px;
    padding: 1.25rem;
    margin-bottom: 1.5rem;
}
.chart-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem; }
.chart-legend { display: flex; align-items: center; gap: 1rem; font-size: 0.75rem; color: #8892a4; }
.legend-dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; margin-right: 0.3rem; }
.legend-dot.portfolio { background: #00e5ff; }
.legend-dot.resume { background: #00786c; }

.chart-wrap { overflow-x: auto; }
.chart-bars {
    display: flex;
    align-items: flex-end;
    gap: 3px;
    height: 120px;
    padding-bottom: 24px;
    min-width: 600px;
}
.bar-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    height: 100%;
    position: relative;
    cursor: default;
}
.bar-stack {
    width: 100%;
    min-height: 2px;
    display: flex;
    flex-direction: column-reverse;
    border-radius: 2px 2px 0 0;
    overflow: hidden;
    transition: opacity 0.2s;
}
.bar-col:hover .bar-stack { opacity: 0.8; }
.bar-portfolio { background: #00e5ff; min-height: 1px; }
.bar-resume    { background: #00786c; min-height: 1px; }
.bar-label {
    position: absolute;
    bottom: 0;
    font-size: 0.55rem;
    color: #8892a4;
    font-family: 'JetBrains Mono', monospace;
    transform: rotate(-45deg);
    transform-origin: top left;
    white-space: nowrap;
}

/* Split grid */
.split-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
}
.split-card {
    background: #0d1220;
    border: 1px solid rgba(0,229,255,0.1);
    border-radius: 8px;
    padding: 1.25rem;
}

/* Page split bars */
.donut-bars { display: flex; flex-direction: column; gap: 1rem; }
.donut-row { display: flex; align-items: center; gap: 0.75rem; }
.donut-label { font-size: 0.78rem; color: #f0f4ff; width: 140px; flex-shrink: 0; }
.donut-label code { font-size: 0.65rem; color: #00e5ff; background: rgba(0,229,255,0.08); padding: 0.05rem 0.3rem; border-radius: 2px; }
.donut-bar-track { flex: 1; height: 8px; background: rgba(255,255,255,0.06); border-radius: 999px; overflow: hidden; }
.donut-bar { height: 100%; border-radius: 999px; min-width: 2px; transition: width 0.5s; }
.donut-bar.portfolio { background: #00e5ff; }
.donut-bar.resume    { background: #00786c; }
.donut-pct { font-size: 0.75rem; color: #8892a4; font-family: 'JetBrains Mono', monospace; width: 45px; text-align: right; }

/* Recent list */
.recent-list { display: flex; flex-direction: column; gap: 0.4rem; max-height: 320px; overflow-y: auto; }
.recent-row { display: flex; align-items: center; gap: 0.6rem; padding: 0.35rem 0; border-bottom: 1px solid rgba(255,255,255,0.04); font-size: 0.78rem; }
.page-badge { font-size: 0.65rem; padding: 0.15rem 0.5rem; border-radius: 999px; font-family: 'JetBrains Mono', monospace; font-weight: bold; }
.page-badge.portfolio { background: rgba(0,229,255,0.12); color: #00e5ff; }
.page-badge.resume    { background: rgba(0,120,108,0.2); color: #00b8a9; }
.recent-locale { font-size: 0.65rem; color: #8892a4; font-family: 'JetBrains Mono', monospace; }
.recent-time { color: #8892a4; margin-left: auto; white-space: nowrap; }
.download-badge { font-size: 0.65rem; color: #f59e0b; background: rgba(245,158,11,0.1); padding: 0.1rem 0.4rem; border-radius: 3px; }

.empty { font-size: 0.85rem; color: #8892a4; padding: 1rem 0; }
</style>
