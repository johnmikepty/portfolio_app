---
import CmsLayout from '@/layouts/CmsLayout.astro'
import { connectDB } from '@/lib/mongodb'
import { Visit } from '@/lib/models/Visit'

await connectDB()

const now        = new Date()
const todayStart = new Date(now); todayStart.setHours(0,0,0,0)
const weekStart  = new Date(now.getTime() - 7  * 24 * 60 * 60 * 1000)
const monthStart = new Date(now.getTime() - 30 * 24 * 60 * 60 * 1000)

const [
    totalVisits, visitsToday, visitsWeek, visitsMonth,
    portfolioTotal, resumeTotal, downloads,
    last30Days, recentVisits,
    byDevice, byCountry,
] = await Promise.all([
    Visit.countDocuments({}),
    Visit.countDocuments({ timestamp: { $gte: todayStart } }),
    Visit.countDocuments({ timestamp: { $gte: weekStart } }),
    Visit.countDocuments({ timestamp: { $gte: monthStart } }),
    Visit.countDocuments({ page: '/' }),
    Visit.countDocuments({ page: '/resume' }),
    Visit.countDocuments({ action: 'download' }),
    Visit.aggregate([
        { $match: { timestamp: { $gte: monthStart } } },
        { $group: {
            _id: { $dateToString: { format: '%Y-%m-%d', date: '$timestamp' } },
            total:     { $sum: 1 },
            portfolio: { $sum: { $cond: [{ $eq: ['$page', '/'] }, 1, 0] } },
            resume:    { $sum: { $cond: [{ $eq: ['$page', '/resume'] }, 1, 0] } },
        }},
        { $sort: { _id: 1 } },
    ]),
    Visit.find({ action: 'view' })
        .sort({ timestamp: -1 })
        .limit(30)
        .lean(),
    // Device breakdown
    Visit.aggregate([
        { $group: { _id: '$device', count: { $sum: 1 } } },
        { $sort: { count: -1 } },
    ]),
    // Country breakdown — top 7
    Visit.aggregate([
        { $match: { country: { $ne: '' } } },
        { $group: { _id: '$country', count: { $sum: 1 } } },
        { $sort: { count: -1 } },
        { $limit: 7 },
    ]),
])

// Fill chart with missing days
const chartData: { date: string; total: number; portfolio: number; resume: number }[] = []
for (let i = 29; i >= 0; i--) {
    const d = new Date(now.getTime() - i * 24 * 60 * 60 * 1000)
    const dateStr = d.toISOString().split('T')[0]
    const found = last30Days.find((r: any) => r._id === dateStr)
    chartData.push({ date: dateStr, total: found?.total ?? 0, portfolio: found?.portfolio ?? 0, resume: found?.resume ?? 0 })
}
const maxCount = Math.max(...chartData.map(d => d.total), 1)

const deviceIcon: Record<string, string> = { desktop: '🖥', mobile: '📱', tablet: '⬜' }
const totalDevices = byDevice.reduce((a: number, d: any) => a + d.count, 0) || 1
const totalCountries = byCountry.reduce((a: number, d: any) => a + d.count, 0) || 1

function flagEmoji(code: string) {
    if (!code || code.length !== 2) return '🌐'
    return String.fromCodePoint(...[...code.toUpperCase()].map(c => 0x1F1E6 + c.charCodeAt(0) - 65))
}
---

<CmsLayout title="Analytics" activeSection="visits">

<!-- HEADER -->
<div class="page-header">
    <div>
        <h1 class="page-title">Analytics</h1>
        <p class="page-sub">Visit tracking &mdash; last 30 days &middot; auto-purge after 90 days</p>
    </div>
</div>

<!-- STAT CARDS -->
<div class="stats-grid">
    <div class="stat-card accent">
        <div class="stat-icon">👁</div>
        <div class="stat-label">Total Visits</div>
        <div class="stat-value">{totalVisits.toLocaleString()}</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon">📅</div>
        <div class="stat-label">Today</div>
        <div class="stat-value">{visitsToday}</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon">📆</div>
        <div class="stat-label">This Week</div>
        <div class="stat-value">{visitsWeek}</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon">⬇</div>
        <div class="stat-label">Downloads</div>
        <div class="stat-value">{downloads}</div>
    </div>
</div>

<!-- CHART -->
<div class="card chart-card">
    <div class="card-head">
        <span class="card-title">Last 30 Days</span>
        <div class="legend">
            <span class="legend-dot cyan"></span><span>Portfolio</span>
            <span class="legend-dot teal"></span><span>Resume</span>
        </div>
    </div>
    <div class="chart-scroll">
        <div class="chart-bars">
            {chartData.map(d => (
                <div class="bar-col" title={`${d.date}: ${d.total}`}>
                    <div class="bar-stack" style={`height:${(d.total/maxCount*100).toFixed(1)}%`}>
                        <div class="bar-resume"    style={`flex:${d.resume || 0}`}></div>
                        <div class="bar-portfolio" style={`flex:${d.portfolio || 0}`}></div>
                    </div>
                    <span class="bar-label">{d.date.slice(5)}</span>
                </div>
            ))}
        </div>
    </div>
</div>

<!-- MIDDLE ROW: Page split + Device + Country -->
<div class="mid-grid">

    <!-- Page split -->
    <div class="card">
        <div class="card-head"><span class="card-title">Page Split</span></div>
        <div class="bar-rows">
            <div class="bar-row">
                <span class="bar-row-label">Portfolio <code>/</code></span>
                <div class="track"><div class="fill cyan" style={`width:${totalVisits?((portfolioTotal/totalVisits)*100).toFixed(1):0}%`}></div></div>
                <span class="bar-row-pct">{totalVisits ? ((portfolioTotal/totalVisits)*100).toFixed(0) : 0}%</span>
            </div>
            <div class="bar-row">
                <span class="bar-row-label">Resume <code>/resume</code></span>
                <div class="track"><div class="fill teal" style={`width:${totalVisits?((resumeTotal/totalVisits)*100).toFixed(1):0}%`}></div></div>
                <span class="bar-row-pct">{totalVisits ? ((resumeTotal/totalVisits)*100).toFixed(0) : 0}%</span>
            </div>
        </div>
        <div class="split-nums">
            <span class="num-chip cyan">{portfolioTotal} portfolio</span>
            <span class="num-chip teal">{resumeTotal} resume</span>
        </div>
    </div>

    <!-- Device breakdown -->
    <div class="card">
        <div class="card-head"><span class="card-title">Devices</span></div>
        <div class="bar-rows">
            {byDevice.length ? byDevice.map((d: any) => (
                <div class="bar-row">
                    <span class="bar-row-label">{deviceIcon[d._id] ?? '?'} {d._id || 'unknown'}</span>
                    <div class="track"><div class="fill cyan" style={`width:${((d.count/totalDevices)*100).toFixed(1)}%`}></div></div>
                    <span class="bar-row-pct">{((d.count/totalDevices)*100).toFixed(0)}%</span>
                </div>
            )) : <p class="empty">No data yet.</p>}
        </div>
    </div>

    <!-- Country breakdown -->
    <div class="card">
        <div class="card-head"><span class="card-title">Top Countries</span></div>
        <div class="bar-rows">
            {byCountry.length ? byCountry.map((c: any) => (
                <div class="bar-row">
                    <span class="bar-row-label">{flagEmoji(c._id)} {c._id || '??'}</span>
                    <div class="track"><div class="fill cyan" style={`width:${((c.count/totalCountries)*100).toFixed(1)}%`}></div></div>
                    <span class="bar-row-pct">{c.count}</span>
                </div>
            )) : <p class="empty">No country data — available in production via CF-IPCountry.</p>}
        </div>
    </div>

</div>

<!-- RECENT VISITS TABLE -->
<div class="card recent-card">
    <div class="card-head">
        <span class="card-title">Recent Visits</span>
        <span class="card-sub">{recentVisits.length} most recent</span>
    </div>
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Page</th>
                    <th>Device</th>
                    <th>Country</th>
                    <th>Locale</th>
                    <th>Date</th>
                </tr>
            </thead>
            <tbody>
                {recentVisits.length ? recentVisits.map((v: any) => (
                    <tr>
                        <td>
                            <span class={`page-badge ${v.page === '/' ? 'cyan' : 'teal'}`}>
                                {v.page === '/' ? 'Portfolio' : 'Resume'}
                            </span>
                        </td>
                        <td><span class="device-cell">{deviceIcon[v.device] ?? '?'} {v.device || '—'}</span></td>
                        <td>{v.country ? `${flagEmoji(v.country)} ${v.country}` : '—'}</td>
                        <td><span class="locale-chip">{(v.locale ?? 'en').toUpperCase()}</span></td>
                        <td class="time-cell">
                            {new Date(v.timestamp).toLocaleString('en', {
                                month: 'short', day: 'numeric',
                                hour: '2-digit', minute: '2-digit',
                            })}
                        </td>
                    </tr>
                )) : (
                    <tr><td colspan="5" class="empty">No visits recorded yet.</td></tr>
                )}
            </tbody>
        </table>
    </div>
</div>

</CmsLayout>

<style>
/* ── Header ─────────────────────────────────────────── */
.page-header { margin-bottom: 1.5rem; padding-bottom: 1.25rem; border-bottom: 1px solid rgba(255,255,255,0.06); }
.page-title  { font-size: 1.4rem; font-weight: 500; color: #f0f4ff; margin-bottom: 0.2rem; }
.page-sub    { font-size: 0.78rem; color: #8892a4; font-family: 'JetBrains Mono', monospace; white-space: nowrap; }

/* ── Stat cards ─────────────────────────────────────── */
.stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.85rem;
    margin-bottom: 1.25rem;
}
.stat-card {
    background: #0d1220;
    border: 1px solid rgba(0,229,255,0.08);
    border-radius: 8px;
    padding: 1rem 1.1rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
}
.stat-card.accent { border-color: rgba(0,229,255,0.3); }
.stat-icon  { font-size: 1rem; }
.stat-label { font-size: 0.68rem; color: #8892a4; font-family: 'JetBrains Mono', monospace; text-transform: uppercase; letter-spacing: 0.06em; }
.stat-value { font-size: 1.9rem; font-weight: 600; color: #00e5ff; line-height: 1.1; }

/* ── Generic card ───────────────────────────────────── */
.card {
    background: #0d1220;
    border: 1px solid rgba(0,229,255,0.08);
    border-radius: 8px;
    padding: 1.1rem 1.25rem;
    margin-bottom: 1.25rem;
}
.card-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
}
.card-title { font-size: 0.72rem; color: #8892a4; font-family: 'JetBrains Mono', monospace; text-transform: uppercase; letter-spacing: 0.08em; }
.card-sub   { font-size: 0.68rem; color: #8892a4; font-family: 'JetBrains Mono', monospace; }

/* ── Chart ──────────────────────────────────────────── */
.chart-card  { margin-bottom: 1.25rem; }
.legend      { display: flex; align-items: center; gap: 0.75rem; font-size: 0.72rem; color: #8892a4; }
.legend-dot  { width: 8px; height: 8px; border-radius: 50%; display: inline-block; margin-right: 0.2rem; }
.legend-dot.cyan { background: #00e5ff; }
.legend-dot.teal { background: #00786c; }

.chart-scroll { overflow-x: auto; width: 100%; }
.chart-bars {
    display: flex;
    align-items: flex-end;
    gap: 3px;
    height: 130px;
    padding-bottom: 22px;
    width: max-content;
    min-width: 100%;
}
.bar-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    height: 100%;
    position: relative;
    cursor: default;
}
.bar-stack {
    width: 100%;
    min-height: 2px;
    display: flex;
    flex-direction: column-reverse;
    border-radius: 2px 2px 0 0;
    overflow: hidden;
}
.bar-col:hover .bar-stack { opacity: 0.75; }
.bar-portfolio { background: #00e5ff; min-height: 1px; }
.bar-resume    { background: #00786c; min-height: 1px; }
.bar-label {
    position: absolute;
    bottom: 0;
    font-size: 0.5rem;
    color: #8892a4;
    font-family: 'JetBrains Mono', monospace;
    transform: rotate(-45deg);
    transform-origin: top left;
    white-space: nowrap;
}

/* ── Mid grid ───────────────────────────────────────── */
.mid-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-bottom: 1.25rem;
}
.mid-grid .card { margin-bottom: 0; }

/* ── Bar rows (page split / device / country) ───────── */
.bar-rows   { display: flex; flex-direction: column; gap: 0.7rem; }
.bar-row    { display: flex; align-items: center; gap: 0.6rem; }
.bar-row-label { font-size: 0.78rem; color: #f0f4ff; width: 130px; flex-shrink: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.bar-row-label code { font-size: 0.62rem; color: #00e5ff; background: rgba(0,229,255,0.08); padding: 0.05rem 0.25rem; border-radius: 2px; }
.track { flex: 1; height: 6px; background: rgba(255,255,255,0.06); border-radius: 999px; overflow: hidden; }
.fill  { height: 100%; border-radius: 999px; min-width: 2px; transition: width 0.5s; }
.fill.cyan { background: #00e5ff; }
.fill.teal { background: #00786c; }
.bar-row-pct { font-size: 0.7rem; color: #8892a4; font-family: 'JetBrains Mono', monospace; width: 36px; text-align: right; flex-shrink: 0; }

.split-nums { display: flex; gap: 0.5rem; margin-top: 0.75rem; }
.num-chip   { font-size: 0.68rem; font-family: 'JetBrains Mono', monospace; padding: 0.15rem 0.5rem; border-radius: 999px; }
.num-chip.cyan { background: rgba(0,229,255,0.1); color: #00e5ff; }
.num-chip.teal { background: rgba(0,120,108,0.15); color: #00b8a9; }

/* ── Recent table ───────────────────────────────────── */
.recent-card { margin-bottom: 0; }
.table-wrap  { overflow-x: auto; }
table { width: 100%; border-collapse: collapse; font-size: 0.8rem; }
thead th {
    font-size: 0.65rem;
    color: #8892a4;
    font-family: 'JetBrains Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    text-align: left;
    padding: 0 0.5rem 0.6rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
}
tbody tr { border-bottom: 1px solid rgba(255,255,255,0.03); transition: background 0.12s; }
tbody tr:hover { background: rgba(255,255,255,0.02); }
tbody tr:last-child { border-bottom: none; }
tbody td { padding: 0.5rem; color: #f0f4ff; vertical-align: middle; }

.page-badge { font-size: 0.65rem; padding: 0.15rem 0.5rem; border-radius: 999px; font-family: 'JetBrains Mono', monospace; font-weight: 600; }
.page-badge.cyan { background: rgba(0,229,255,0.12); color: #00e5ff; }
.page-badge.teal { background: rgba(0,120,108,0.2);  color: #00b8a9; }

.device-cell { font-size: 0.78rem; color: #8892a4; }
.locale-chip { font-size: 0.62rem; font-family: 'JetBrains Mono', monospace; background: rgba(255,255,255,0.06); padding: 0.1rem 0.35rem; border-radius: 3px; color: #8892a4; }
.time-cell   { color: #8892a4; font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; white-space: nowrap; }

.empty { font-size: 0.82rem; color: #8892a4; padding: 0.5rem 0; }
</style>
