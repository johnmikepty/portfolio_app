---
import type { Locale } from '@/i18n'

interface Props { locale: Locale }
const { locale } = Astro.props
---

<div class="lang-toggle" title="Switch language / Cambiar idioma">
    <button
        class={locale === 'en' ? 'active' : ''}
        data-lang="en"
        aria-label="Switch to English"
    >
        🇺🇸 EN
    </button>
    <span class="divider">|</span>
    <button
        class={locale === 'es' ? 'active' : ''}
        data-lang="es"
        aria-label="Cambiar a Español"
    >
        🇵🇦 ES
    </button>
</div>

<script>
    document.querySelectorAll<HTMLButtonElement>('.lang-toggle button').forEach(btn => {
        btn.addEventListener('click', async () => {
            const lang = btn.dataset.lang
            if (!lang) return

            await fetch('/api/set-lang', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ lang }),
            })

            window.location.reload()
        })
    })
</script>

<style>
    .lang-toggle {
        position: fixed;
        top: 1rem;
        right: 1rem;
        z-index: 100;
        display: flex;
        align-items: center;
        gap: 0.4rem;
        background: var(--col-bg, #fff);
        border: 1.5px solid var(--col-fg, #222);
        border-radius: 999px;
        padding: 0.3rem 0.75rem;
        font-size: 0.85rem;
        box-shadow: 0 2px 8px rgba(0,0,0,0.12);

        @media print {
            display: none;
        }
    }

    button {
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.1rem 0.3rem;
        border-radius: 999px;
        font-size: 0.85rem;
        color: var(--col-fg, #222);
        opacity: 0.5;
        transition: opacity 0.15s, background 0.15s;
    }

    button:hover {
        opacity: 0.85;
    }

    button.active {
        opacity: 1;
        font-weight: bold;
        background: var(--col-primary, #0066cc);
        color: #fff;
    }

    .divider {
        opacity: 0.3;
    }
</style>
