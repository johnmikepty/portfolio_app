---
import { Icon } from 'astro-icon/components'
import { getExperienceDB } from '@/lib/profile'
import { getDisplayDate } from '@/util'
import { getTranslations, type Locale } from '@/i18n'
import { markdownInline } from '@/lib/markdown'

interface Props { locale: Locale }
const { locale } = Astro.props
const t = getTranslations(locale)
const experience = await getExperienceDB(locale)
---

<section id="experience" data-item-count={experience.length}>
    <div class="section-title">
        <h2>{t.sections.experience}</h2>
        <Icon name="ri:briefcase-4-fill" />
    </div>

    <div>
        {experience.map(({ name, url, title, location, startYear, startMonth, endYear, endMonth, bullets }) => (
            <article class="experience">
                <div class="header">
                    <h3 class="title">{title}</h3>

                    <span>&mdash;</span>

                    <div class="company-name">
                        <span class="personal">{name}</span>
                        {url && (
                            <a href={url} target="_blank" referrerpolicy="no-referrer" class="ez-click is-icon">
                                <Icon name="ri:external-link-line" />
                            </a>
                        )}
                    </div>

                    <div class="grow" />

                    <div class="location">
                        {location && (
                            <Icon name="ri:map-pin-2-line" />
                            <span class="personal">{location}</span>
                        )}
                    </div>

                    <span>&mdash;</span>

                    <div class="dates">
                        <Icon name="ri:calendar-line" />
                        <span>
                            {getDisplayDate(startYear, startMonth, locale, t.ui.present)}
                            {' - '}
                            {getDisplayDate(endYear, endMonth, locale, t.ui.present)}
                        </span>
                    </div>
                </div>

                <ul>
                    {bullets.map((b: string) => <li set:html={markdownInline(b)} />)}
                </ul>
            </article>
        ))}
    </div>
</section>

<style>
    #experience {
        page-break-inside: auto;
        break-inside: auto;
    }

    .header {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 1ch;
    }

    .company-name {
        display: flex;
        justify-content: center;
        align-items: baseline;
        font-weight: bold;
        gap: 0.5ch;
    }

    .location {
        font-style: italic;
    }

    .dates {
        font-weight: bold;
    }

    .location svg {
        vertical-align: top;
    }

    ul {
        margin: 0.25rem 0 1rem;
        padding-left: 1.25rem;
    }
</style>
