---
import { Icon } from 'astro-icon/components'
import { getCertificationsDB } from '@/lib/profile'
import { getTranslations, type Locale } from '@/i18n'

interface Props { locale: Locale }
const { locale } = Astro.props
const t = getTranslations(locale)
const certifications = await getCertificationsDB()
---

<section id="certifications" data-item-count={certifications.length}>
    <div class="section-title">
        <h2>{t.sections.certifications}</h2>
        <Icon name="ri:briefcase-4-fill" />
    </div>

    <div>
        {certifications.map(({ mentorship, title, website, year }) => (
            <article class="certifications">
                <div class="header">
                    <h3 class="title">{title}</h3>

                    <span>&mdash;</span>

                    <div class="company-name">
                        <span class="personal">{mentorship}</span>
                        {website && (
                            <a href={website} target="_blank" referrerpolicy="no-referrer" class="ez-click is-icon">
                                <Icon name="ri:external-link-line" />
                            </a>
                        )}
                    </div>

                    <span>&mdash;</span>

                    <div class="dates">
                        <Icon name="ri:calendar-line" />
                        <span>{year}</span>
                    </div>
                </div>
            </article>
        ))}
    </div>
</section>

<style>
    #certifications {
        page-break-inside: auto;
        break-inside: auto;
    }

    .header {
        display: flex;
        align-items: baseline;
        gap: 1ch;
    }

    .company-name {
        display: flex;
        justify-content: center;
        align-items: baseline;
        font-weight: bold;
        gap: 0.5ch;
    }

    .dates {
        font-weight: bold;
    }
</style>
