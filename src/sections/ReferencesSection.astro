---
import { Icon } from 'astro-icon/components'
import { getReferencesDB } from '@/lib/profile'
import { getTranslations, type Locale } from '@/i18n'

interface Props { locale: Locale }
const { locale } = Astro.props
const t = getTranslations(locale)
const references = await getReferencesDB()
---

<section id="references" data-item-count={references.length}>
    <div class="section-title">
        <h2>{t.sections.references}</h2>
        <Icon name="ri:suitcase-fill" />
    </div>

    <article>
        <ul>
            {references.map(({ name, title, company, email, phone }) => (
                <li>
                    <span class="name personal">{name}</span>
                    <span>{title} {t.ui.at} <span class="personal">{company}</span></span>
                    {email && <span class="personal">{email}</span>}
                    {phone && <span class="personal">{phone}</span>}
                </li>
            ))}
        </ul>
    </article>
</section>

<style>
    .name {
        font-weight: bold;
    }

    li > *:not(:last-child)::after {
        content: " — ";
        display: inline;
    }
</style>

<style is:global>
    body.hide-references #references {
        display: none;
    }
</style>
