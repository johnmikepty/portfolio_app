---
import { Icon } from 'astro-icon/components'
import { getPersonal } from '@/lib/profile'
import type { Locale } from '@/i18n'

interface Props { locale: Locale }
const { locale } = Astro.props

const { name, title, email, phone, linkedin, github, bio, bioHtml } = await getPersonal(locale)
---

<section id="summary">
    <h1 class="personal full-name">{name}</h1>

    <div class="contacts">
        <div>
            <Icon name="logos:linkedin-icon" />
            <a href={`https://linkedin.com/in/${linkedin}`} class="personal">linkedin.com/in/{linkedin}</a>
        </div>
        |
        <div>
            <Icon name="ri:phone-fill" class="text-primary" />
            <span class="personal">{phone}</span>
        </div>
        |
        <div>
            <Icon name="logos:github-icon" />
            <a href={`https://github.com/${github}`} class="personal">github.com/{github}</a>
        </div>
        |
        <div>
            <Icon name="ri:mail-send-fill" class="text-primary" />
            <span class="personal">{email}</span>
        </div>
    </div>

    {title && <h3 class="title">{title}</h3>}

    <div class="summary-text">
        {bioHtml && <Fragment set:html={bioHtml} />}
        <p>{bio}</p>
    </div>
</section>

<style>
    #summary {
        display: flex;
        flex-direction: column;
        justify-content: center;
        text-align: center;
    }

    .summary-text {
        text-align: justify;
    }

    .contacts {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.5em;
        border-bottom: 1.5px solid var(--col-fg);
        padding-bottom: 0.5rem;
        margin-bottom: 0.25rem;

        & > * {
            display: flex;
            gap: 0.5ch;
            justify-content: center;
            align-items: center;
        }
    }
</style>

<style is:global>
    body.hide-summary {
        & .summary-text {
            display: none;
        }
        & .contacts {
            border-bottom: 0;
        }
    }
</style>
