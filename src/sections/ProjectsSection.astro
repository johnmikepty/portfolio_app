---
import { Icon } from 'astro-icon/components'
import { getProjectsDB } from '@/lib/profile'
import { getTranslations, type Locale } from '@/i18n'
import { markdownInline } from '@/lib/markdown'

interface Props { locale: Locale }
const { locale } = Astro.props
const t = getTranslations(locale)
const projects = await getProjectsDB(locale)
---

<section id="projects" data-item-count={projects.length}>
    <div class="section-title">
        <h2>{t.sections.projects}</h2>
        <Icon name="ri:open-source-fill" />
    </div>

    <div class="projects">
        {projects.map(({ name, bullets }) => (
            <article>
                <div class="title">
                    <h3>{name}</h3>
                </div>
                {bullets?.length > 0 && (
                    <ul>
                        {bullets.map((b: string) => <li set:html={markdownInline(b)} />)}
                    </ul>
                )}
            </article>
        ))}
    </div>
</section>

<style>
    .title { display: flex; justify-content: space-between; align-items: center; gap: 2ch; }
    ul { margin: 0.25rem 0 0.5rem; padding-left: 1.25rem; }
</style>

<style is:global>
    body.hide-projects #projects { display: none; }
</style>
