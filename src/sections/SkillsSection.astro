---
import { Icon } from 'astro-icon/components'
import { getSkillSectionsDB } from '@/lib/profile'
import { getTranslations, type Locale } from '@/i18n'

interface Props { locale: Locale }
const { locale } = Astro.props
const t = getTranslations(locale)
const skillGroups = await getSkillSectionsDB()
---

<section id="skills" data-item-count={skillGroups.length}>
    <div class="section-title">
        <h2>{t.sections.skills}</h2>
        <Icon name="ri:code-s-slash-fill" />
    </div>

    <article>
        {skillGroups.map(({ title, items }) => (
            <div class="skill-group">
                <p><strong>{title}:</strong> {items.join(', ')}</p>
            </div>
        ))}
    </article>
</section>
